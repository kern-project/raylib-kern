//! Compile-time coverage for the public wrapper API surface.

use raylib;

const TITLE = "compile-only\0";
const TEXT = "hello\0";
const TEXTURE_PATH = "missing.png\0";

// Touches window functions without relying on a real interactive window.
fn use_window_api() void {
    let win = raylib.window.open(640, 480, TITLE)
        .target_fps(60)
        .title(TITLE);
    _ = win.is_open();
    _ = win.should_close();
    _ = win.is_ready();
    _ = win.fps();
    _ = win.frame_time();
    _ = win.time();
    win.close();
}

// Touches drawing functions so signature drift breaks compilation early.
fn use_drawing_api() void {
    let p = raylib.vector2(10.0, 20.0);
    let q = raylib.vector2(30.0, 40.0);
    let size = raylib.vector2(50.0, 60.0);
    let rec = raylib.rectangle(
        1.0,
        2.0,
        3.0,
        4.0,
    );

    raylib.drawing.frame()
        .clear(raylib.RAYWHITE)
        .pixel(1, 2, raylib.RED)
        .line(0, 0, 10, 10, raylib.BLUE)
        .line_between(p, q, raylib.GREEN)
        .circle(20, 20, 10.0, raylib.ORANGE)
        .circle_at(p, 8.0, raylib.PURPLE)
        .rect(1, 2, 3, 4, raylib.GRAY)
        .rect_rec(rec, raylib.BLACK)
        .rect_lines(1, 2, 3, 4, raylib.WHITE)
        .fps(10, 10)
        .text(TEXT, 10, 40, 20, raylib.DARKGRAY)
        .end();
    _ = size;
    p.draw_pixel(raylib.RED);
    p.draw_circle(8.0, raylib.BLUE);
    p.draw_line_to(q, raylib.GREEN);
    rec.draw(raylib.BLACK);
    rec.draw_lines(1.0, raylib.WHITE);
    _ = rec.contains(p);
    _ = rec.overlaps(rec);
    _ = p.inside_rect(rec);
    let _ = TEXT.measure(20);
}

// Touches keyboard and mouse functions.
fn use_input_api() void {
    _ = raylib.Key.A.pressed();
    _ = raylib.Key.SPACE.down();
    _ = raylib.Key.ESCAPE.released();
    _ = raylib.Key.ENTER.up();
    _ = raylib.MouseButton.LEFT.pressed();
    _ = raylib.MouseButton.RIGHT.down();
    _ = raylib.MouseButton.MIDDLE.released();
    _ = raylib.MouseButton.LEFT.up();
    _ = raylib.input.mouse_position();
    _ = raylib.input.mouse_delta();
}

// Touches texture functions without requiring the test to load a real asset.
fn use_texture_api() void {
    let tex = raylib.textures.load_texture(TEXTURE_PATH)..&;
    let pos = raylib.vector2(0.0, 0.0);
    let src = raylib.rectangle(
        0.0,
        0.0,
        16.0,
        16.0,
    );
    tex.draw(0, 0, raylib.WHITE);
    tex.draw_at(pos, raylib.WHITE);
    tex.draw_ex(
        pos,
        0.0,
        1.0,
        raylib.WHITE,
    );
    tex.draw_rec(src, pos, raylib.WHITE);
    tex.gen_mipmaps();
    tex.unload();
}

// Touches module paths so the focused public modules remain part of the API.
fn use_module_api() void {
    let rec = raylib.rectangle(
        0.0,
        0.0,
        16.0,
        16.0,
    );
    let pos = raylib.vector2(0.0, 0.0);
    let color = raylib.WHITE.alpha(0.5);
    let image = raylib.images.gen_image_color(16, 16, color)..&;
    _ = image.is_valid();
    image.flip_vertical();
    image.draw_text(
        TEXT,
        1,
        1,
        8,
        raylib.BLACK,
    );
    let tex = image.to_texture();
    _ = tex.is_valid();
    tex.draw_rec(rec, pos, raylib.WHITE);
    _ = raylib.text.measure_text(TEXT, 20);
    _ = raylib.input.get_mouse_position();
    _ = raylib.files.file_exists(TEXTURE_PATH);
    tex.unload();
    image.unload();

    let audio = raylib.audio.open().volume(1.0);
    _ = audio.is_ready();
    _ = audio.current_volume();
    let sound = raylib.audio.load_sound("missing.wav\0")..&;
    _ = sound.is_valid();
    sound.set_volume(0.5).play();
    sound.stop();
    sound.unload();
    audio.close();
}

// Entry point for the compile-only test.
fn main() i32 {
    // Keep these calls behind an impossible branch so the test locks API shape
    // without opening a real window in CI or headless development shells.
    if (false) {
        use_window_api();
        use_drawing_api();
        use_input_api();
        use_texture_api();
        use_module_api();
    }
    return 0;
}
